{
"$schema": "https://json-schema.org/draft/2020-12/schema",
"$id": "ai-agent-layer.schema.json",
"title": "AI Agent Layer Schema",
"description": "Schema for the AI Agent Layer in Earth Brain OS v0.2 Modular Event Architecture.",
"type": "object",
"additionalProperties": false,
"required": [
"layer_id",
"layer_name",
"layer_version",
"purpose",
"agent_role",
"agent_type",
"autonomy_level",
"interaction_scope",
"input_channels",
"output_channels",
"reasoning_modes",
"trace_requirements",
"governance_constraints",
"human_review_boundary",
"status"
],
"properties": {
"layer_id": {
"type": "string",
"description": "Unique identifier for this AI agent layer instance.",
"examples": [
"ai-agent-layer-001"
]
},
"layer_name": {
"type": "string",
"const": "AI Agent Layer",
"description": "Canonical name of this layer."
},
"layer_version": {
"type": "string",
"description": "Version of this layer schema or implementation.",
"pattern": "^v[0-9]+\\.[0-9]+(\\.[0-9]+)?(-[A-Za-z0-9.-]+)?$",
"examples": [
"v0.2.0"
]
},
"purpose": {
"type": "string",
"description": "Purpose of the AI agent layer within Earth Brain OS.",
"examples": [
"Coordinate AI agents that interpret, reason, assist, and route events across the Earth Brain OS."
]
},
"agent_role": {
"type": "string",
"description": "Primary role assigned to the AI agent layer.",
"enum": [
"observer",
"assistant",
"reasoner",
"orchestrator",
"translator",
"guardian",
"auditor",
"router",
"coordinator"
]
},
"agent_type": {
"type": "string",
"description": "Type of AI agent represented by this layer.",
"enum": [
"single_agent",
"multi_agent_system",
"human_ai_team",
"local_light_agent",
"edge_agent",
"cloud_agent",
"hybrid_agent"
]
},
"autonomy_level": {
"type": "string",
"description": "Permitted autonomy level of the AI agent layer.",
"enum": [
"advisory_only",
"human_confirmed_action",
"bounded_autonomous_action",
"supervised_autonomous_action",
"restricted"
]
},
"interaction_scope": {
"type": "array",
"description": "Domains or layers this AI agent layer may interact with.",
"minItems": 1,
"uniqueItems": true,
"items": {
"type": "string",
"enum": [
"human_governance",
"knowledge_cortex",
"trace_attribution",
"royalty_circulation",
"kazene_regulation",
"defense_immune",
"optical_nervous",
"external_systems"
]
}
},
"input_channels": {
"type": "array",
"description": "Input channels accepted by the AI agent layer.",
"minItems": 1,
"uniqueItems": true,
"items": {
"type": "string",
"enum": [
"human_prompt",
"system_event",
"sensor_signal",
"trace_record",
"knowledge_query",
"governance_instruction",
"defense_alert",
"royalty_event",
"external_api"
]
}
},
"output_channels": {
"type": "array",
"description": "Output channels produced by the AI agent layer.",
"minItems": 1,
"uniqueItems": true,
"items": {
"type": "string",
"enum": [
"assistant_response",
"structured_event",
"routing_decision",
"trace_update",
"governance_recommendation",
"defense_signal",
"royalty_signal",
"human_review_request"
]
}
},
"reasoning_modes": {
"type": "array",
"description": "Reasoning modes available to this AI agent layer.",
"minItems": 1,
"uniqueItems": true,
"items": {
"type": "string",
"enum": [
"retrieval_augmented_reasoning",
"structural_reasoning",
"causal_reasoning",
"policy_guided_reasoning",
"trace_aware_reasoning",
"breathing_reasoning",
"defensive_reasoning",
"low_power_reasoning"
]
}
},
"compute_profile": {
"type": "object",
"description": "Optional compute profile for energy and deployment constraints.",
"additionalProperties": false,
"properties": {
"deployment_mode": {
"type": "string",
"enum": [
"local",
"edge",
"cloud",
"hybrid"
]
},
"energy_policy": {
"type": "string",
"enum": [
"energy_aware",
"low_power_preferred",
"performance_priority",
"adaptive"
]
},
"model_size_class": {
"type": "string",
"enum": [
"small",
"medium",
"large",
"mixture",
"unspecified"
]
}
}
},
"memory_profile": {
"type": "object",
"description": "Optional memory profile used by this AI agent layer.",
"additionalProperties": false,
"properties": {
"memory_scope": {
"type": "string",
"enum": [
"stateless",
"session_memory",
"project_memory",
"long_term_memory",
"federated_memory"
]
},
"memory_policy": {
"type": "string",
"enum": [
"no_retention",
"explicit_retention_only",
"bounded_retention",
"governed_retention"
]
},
"trace_link_required": {
"type": "boolean",
"description": "Whether memory use requires trace attribution."
}
}
},
"trace_requirements": {
"type": "object",
"description": "Traceability requirements for AI agent activity.",
"additionalProperties": false,
"required": [
"input_trace_required",
"output_trace_required",
"decision_log_required"
],
"properties": {
"input_trace_required": {
"type": "boolean"
},
"output_trace_required": {
"type": "boolean"
},
"decision_log_required": {
"type": "boolean"
},
"trace_reference": {
"type": "string",
"description": "Optional reference to a trace record or attribution event."
}
}
},
"governance_constraints": {
"type": "array",
"description": "Governance constraints applied to the AI agent layer.",
"minItems": 1,
"items": {
"type": "string",
"enum": [
"human_oversight_required",
"policy_compliance_required",
"source_attribution_required",
"privacy_boundary_required",
"safety_review_required",
"royalty_policy_awareness_required",
"defense_boundary_required"
]
}
},
"risk_controls": {
"type": "array",
"description": "Optional risk controls applied to this layer.",
"uniqueItems": true,
"items": {
"type": "string",
"enum": [
"prompt_injection_detection",
"hallucination_check",
"source_verification",
"rate_limiting",
"human_escalation",
"defensive_mode",
"fallback_to_safe_response"
]
}
},
"human_review_boundary": {
"type": "object",
"description": "Boundary conditions for human review.",
"additionalProperties": false,
"required": [
"review_required",
"review_trigger"
],
"properties": {
"review_required": {
"type": "boolean"
},
"review_trigger": {
"type": "array",
"minItems": 1,
"items": {
"type": "string",
"enum": [
"high_impact_decision",
"external_action",
"governance_change",
"royalty_allocation_change",
"defense_escalation",
"uncertain_reasoning",
"user_request"
]
}
}
}
},
"status": {
"type": "string",
"description": "Current operational status of the AI agent layer.",
"enum": [
"draft",
"active",
"review_required",
"restricted",
"deprecated"
]
},
"notes": {
"type": "string",
"description": "Optional implementation notes."
}
}
}
